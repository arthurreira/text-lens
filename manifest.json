{
  "manifest_version": 3,
  "name": "Text Lens – Hover Magnifier",
  "short_name": "Text Lens",
  "version": "1.0.0",
  "description": "Hold Control and hover to magnify readable text under your cursor.",

  "permissions": ["storage", "contextMenus"],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "options_page": "options.html",

  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}